# this script is specifically to make a forest plot
# forest plot is a graphical chart used in research to display results of multiple studies addressing the same question
# you can use the {meta}, {metafor} or {metaviz} packages in R to make these plots

# install and call the necessary libraries
install.packages("ggplot2")
install.packages("metafor")
install.packages("meta")
library(ggplot2)
library(metafor)
library(meta)


# upload the database
# be careful of what type of file you are using because they can have different separators like ',' or ';' 
tab_colesterol <- read.csv2("C:/Users/anajs/Desktop/colesterol_levels.CSV")


# metacont is a function from the {meta} package
# description of metacont from documentation: Calculation of common and random effects estimates for meta-analyses with continuous outcome data; inverse variance weighting is used for pooling.

m.cont <- metacont(n.e = n.e,
            mean.e = mean.e,
            sd.e = sd.e,
            n.c = n.c,
            mean.c = mean.c,
            sd.c = sd.c,
            studlab = studlab,
            data = tab_colesterol,
            sm = "SMD",
            method.smd = "Hedges",
            common = FALSE,
            random = TRUE,
            method.tau = "REML",
            method.random.ci = "HK",
            title = "cholesterol levels")

summary(m.cont)

# forest plot
forest (
  m.cont,
  xlab = "Standardized Mean Difference"
)
